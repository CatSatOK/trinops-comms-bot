# --- Runtime mode -----------------------------------------------------------
# true  = no external services needed: bundled demo FAQ page, escalation
#         emails written to data/outbox/, sample conversations seeded
# false = real Gmail escalation emails (requires Google OAuth credentials)
DEMO_MODE=true

# --- Admin API auth ----------------------------------------------------------
# Protects the staff conversations + admin endpoints when DEMO_MODE=false. Send
# it as the X-API-Key request header. The customer chat WebSocket stays open.
# Leave empty in demo mode (auth is disabled there).
ADMIN_API_KEY=

# --- Chat WebSocket guards ----------------------------------------------------
# The public chat WebSocket is unauthenticated, so it has its own limits.
# Max messages accepted per caller IP per minute (0 disables it). This is the
# main cap on Anthropic spend, since the LLM fallback runs per message.
CHAT_RATE_LIMIT_PER_MINUTE=30
# Longer inbound messages are truncated to this many characters server-side.
MAX_MESSAGE_CHARS=1000
# JSON list of allowed browser origins for the chat WebSocket. When set, the
# connection is refused unless the Origin header matches. Empty allows any
# origin so the embeddable widget works on any host, e.g.
# ALLOWED_ORIGINS=["https://www.example.com","https://example.com"]
ALLOWED_ORIGINS=[]

# --- Database ----------------------------------------------------------------
# SQLite for demo; swap for PostgreSQL in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/comms
DATABASE_URL=sqlite:///./data/comms.db

# --- Claude fallback (optional) ------------------------------------------------
# Leave empty to disable the LLM fallback entirely; unmatched questions then
# get a polite fallback reply that points the visitor at escalation.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Knowledge base -------------------------------------------------------------
# faq_source is what the scraper reads: your live FAQ page URL in production,
# the bundled demo page in demo mode. Local file paths work too.
FAQ_FILE=knowledge_base/faq.json
FAQ_SOURCE=demo/faq-page.html
# Re-scrape cadence in hours; 0 disables the scheduled refresh
FAQ_REFRESH_HOURS=24

# --- Matching ---------------------------------------------------------------------
# rapidfuzz token_set_ratio score (0-100) needed to answer from the FAQ
FUZZY_MATCH_THRESHOLD=80
# How many Q&A pairs are injected as context on a Claude fallback call
LLM_MAX_CONTEXT_PAIRS=40

# --- Escalation ----------------------------------------------------------------
# JSON list of phrases that trigger a human handoff (word-boundary matched)
ESCALATION_KEYWORDS=["speak to someone","speak to a person","talk to someone","talk to a person","human","agent","real person","complaint"]
CS_TEAM_EMAIL=support@example.com

# --- Company details --------------------------------------------------------------
COMPANY_NAME=Company A
COMPANY_EMAIL=hello@example.com

# --- Google APIs (only used when DEMO_MODE=false) -----------------------------------
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# --- Paths ----------------------------------------------------------------------------
OUTBOX_DIR=data/outbox
SEED_CONVERSATIONS_FILE=seed/conversations.json
